# Sage Environment Configuration
# Copy this file to .env and fill in your values.
# Real environment variables (export SAGE_...) take priority over this file.

# Qwen API key (required for live LLM mode)
SAGE_QWEN_API_KEY=

# Required for every non-health API request. Use a long random value.
SAGE_ADMIN_TOKEN=

# Live Qwen and Alibaba Cloud execution is disabled unless explicitly enabled.
SAGE_ENABLE_LIVE=false

# Separate emergency switch for billable/destructive Alibaba Cloud operations.
SAGE_ALLOW_CLOUD_MUTATIONS=false

# Browser origins allowed to call the API (comma-separated, no wildcard).
SAGE_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SAGE_ALLOWED_REGIONS=ap-northeast-1,ap-northeast-2,ap-south-1,ap-southeast-1,ap-southeast-2,ap-southeast-3,ap-southeast-5,ap-southeast-6,ap-southeast-7, ap-southeast-8,eu-central-1,eu-west-1,eu-west-2,na-south-1, us-east-1,us-west-1

# Per-Run provider spend guards.
SAGE_MAX_LLM_ATTEMPTS=24
SAGE_MAX_LLM_TOKENS=50000
SAGE_MAX_RUN_SECONDS=55


# Bounded background Run worker and retention limits.
SAGE_JOB_WORKERS=2
SAGE_MAX_RETAINED_JOBS=500

# Note: Alibaba Cloud credentials are entered via the web UI and stored in
# server memory only — never written to disk or environment variables.
